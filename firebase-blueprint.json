{
  "entities": {
    "report": {
      "title": "Stolen or Lost Device Report",
      "description": "Represents a mobile phone theft or loss report details with full owner and device information.",
      "type": "object",
      "properties": {
        "ownerName": { "type": "string", "description": "Full name of the owner." },
        "nicNumber": { "type": "string", "description": "Pakistani CNIC of the owner." },
        "address": {
          "type": "object",
          "properties": {
            "street": { "type": "string" },
            "town": { "type": "string" },
            "city": { "type": "string" }
          }
        },
        "contactNumber": { "type": "string" },
        "whatsappNumber": { "type": "string" },
        "lossDateTime": { "type": "string", "format": "date-time" },
        "lossLocation": { "type": "string" },
        "imei": { "type": "string" },
        "imei2": { "type": "string" },
        "brand": { "type": "string" },
        "model": { "type": "string" },
        "color": { "type": "string" },
        "reportType": { "type": "string", "enum": ["stolen", "lost"] },
        "description": { "type": "string" },
        "hasPoliceReport": { "type": "string", "enum": ["yes", "no"] },
        "proofType": { "type": "string", "enum": ["police_report", "box_image", "purchase_slip"] },
        "proofImageUrl": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "verified", "flagged"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "userId": { "type": "string" },
        "userEmail": { "type": "string" }
      },
      "required": ["ownerName", "nicNumber", "address", "contactNumber", "whatsappNumber", "lossDateTime", "lossLocation", "imei", "brand", "model", "color", "reportType", "status", "createdAt", "userId", "userEmail", "hasPoliceReport", "proofType", "proofImageUrl"]
    },
    "fakeReport": {
      "title": "Fake Entry Report",
      "description": "User report flagging a phone entry as fake or suspicious.",
      "type": "object",
      "properties": {
        "phoneId": { "type": "string", "description": "ID of the phone entry being flagged." },
        "reporterId": { "type": "string", "description": "UID of the user reporting." },
        "reporterEmail": { "type": "string" },
        "reason": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["phoneId", "reporterId", "reporterEmail", "createdAt"]
    },
    "recovery": {
      "title": "Recovery Success Story",
      "description": "Information about a successfully recovered mobile phone.",
      "type": "object",
      "properties": {
        "phoneId": { "type": "string" },
        "ownerName": { "type": "string" },
        "brand": { "type": "string" },
        "model": { "type": "string" },
        "city": { "type": "string" },
        "foundBy": { "type": "string" },
        "finderCity": { "type": "string" },
        "recoveryNote": { "type": "string" },
        "recoveredAt": { "type": "string", "format": "date-time" }
      },
      "required": ["phoneId", "ownerName", "brand", "model", "city", "foundBy", "finderCity", "recoveredAt"]
    }
  },
  "firestore": {
    "phones": {
      "schema": "report",
      "description": "Central registry of stolen/lost mobile devices in Pakistan."
    },
    "reports": {
      "schema": "fakeReport",
      "description": "User-submitted flags for suspicious entries."
    },
    "flagged": {
      "schema": "report",
      "description": "Entries that have been hidden from public due to suspicion."
    },
    "recoveries": {
      "schema": "recovery",
      "description": "Public records of successfully recovered phones."
    }
  }
}

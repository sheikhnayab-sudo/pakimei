rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Default deny all (MUST be at top)
    match /{document=**} {
      allow read, write: if false;
    }

    // Global Helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && 
             'email' in request.auth.token && 
             request.auth.token.email.lower() == 'sheikhnayab@gmail.com';
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isValidReport(data) {
      return data.keys().hasAll([
               'ownerName', 'imei', 'brand', 'model', 'city', 'status', 'createdAt', 'userId', 'userEmail'
             ]) &&
             data.ownerName is string && data.ownerName.size() >= 3 && data.ownerName.size() <= 100 &&
             data.city is string &&
             data.imei is string && data.imei.size() == 15 &&
             data.brand is string &&
             data.model is string && data.model.size() <= 100 &&
             data.status in ['pending', 'verified', 'flagged', 'recovered'] &&
             data.userId is string && data.userId.size() <= 128 &&
             data.userEmail is string && data.userEmail.size() <= 200;
    }

    function isValidRecovery(data) {
      return data.keys().hasAll([
               'phoneId', 'ownerName', 'brand', 'model', 'city', 'foundBy', 'finderCity', 'recoveryNote', 'recoveredAt'
             ]) &&
             data.keys().size() == 9 &&
             data.phoneId is string &&
             data.ownerName is string &&
             data.brand is string &&
             data.model is string &&
             data.city is string &&
             data.foundBy is string &&
             data.finderCity is string &&
             data.recoveryNote is string &&
             data.recoveredAt == request.time;
    }

    // RECOVERIES COLLECTION
    match /recoveries/{docId} {
      allow read: if true;
      allow create: if isSignedIn() && isValidRecovery(incoming());
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // PHONE REGISTRY COLLECTION
    match /phones/{reportId} {
      allow read: if true;
      allow create: if isSignedIn() && isValidId(reportId) && isValidReport(incoming()) && incoming().userId == request.auth.uid && incoming().status == 'pending' && incoming().verified == false && incoming().createdAt == request.time;
      allow update: if isSignedIn() && (isAdmin() || (isOwner(existing().userId) && incoming().userId == existing().userId && incoming().imei == existing().imei && incoming().createdAt == existing().createdAt));
      allow delete: if isAdmin() || isOwner(existing().userId);
    }

    // TRASH SYSTEM
    match /trash/{docId} {
      allow read, write: if isAdmin();
    }

    // SUPPORTING COLLECTIONS
    match /reports/{docId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update, delete: if isAdmin() || isOwner(existing().userId);
    }

    match /flagged/{docId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isAdmin() || isOwner(existing().userId);
    }
  }
}

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Default deny all (MUST be at top)
    match /{document=**} {
      allow read, write: if false;
    }

    // Global Helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && 
             'email' in request.auth.token && 
             request.auth.token.email.lower() == 'sheikhnayab@gmail.com';
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isValidReport(data) {
      return data.keys().hasAll([
               'ownerName', 'nicNumber', 'address', 'contactNumber', 'whatsappNumber', 
               'lossDateTime', 'lossLocation', 'imei', 'imei2', 'brand', 'model', 'color', 
               'reportType', 'description', 'status', 'createdAt', 'userId', 'userEmail', 
               'verified', 'hasPoliceReport', 'proofType', 'proofImageUrl', 'selfieImageUrl', 'city'
             ]) &&
             data.keys().size() == 24 &&
             data.ownerName is string && data.ownerName.size() >= 3 && data.ownerName.size() <= 100 &&
             data.nicNumber is string && data.nicNumber.matches('^[0-9]{5}-[0-9]{7}-[0-9]{1}$') &&
             data.address is map &&
             data.address.city is string &&
             data.city is string &&
             data.contactNumber is string && data.contactNumber.size() <= 15 &&
             data.whatsappNumber is string && data.whatsappNumber.size() <= 15 &&
             data.lossLocation is string && data.lossLocation.size() <= 256 &&
             data.imei is string && data.imei.size() == 15 &&
             data.imei2 is string && (data.imei2 == "" || data.imei2.size() == 15) &&
             data.brand is string &&
             data.model is string && data.model.size() <= 100 &&
             data.color is string && data.color.size() <= 64 &&
             data.reportType in ['stolen', 'lost'] &&
             data.description is string && data.description.size() <= 1000 &&
             data.hasPoliceReport in ['yes', 'no'] &&
             data.proofType in ['police_report', 'box_image', 'purchase_slip'] &&
             data.proofImageUrl is string && (data.proofImageUrl == "" || data.proofImageUrl.size() <= 1024) &&
             data.selfieImageUrl is string && (data.selfieImageUrl == "" || data.selfieImageUrl.size() <= 1024) &&
             data.status in ['pending', 'verified', 'flagged', 'recovered'] &&
             data.verified is bool &&
             data.userId is string && data.userId.size() <= 128 &&
             data.userEmail is string && data.userEmail.size() <= 200;
    }

    function isValidRecovery(data) {
      return data.keys().hasAll([
               'phoneId', 'ownerName', 'brand', 'model', 'city', 'foundBy', 'finderCity', 'recoveryNote', 'recoveredAt'
             ]) &&
             data.keys().size() == 9 &&
             data.phoneId is string &&
             data.ownerName is string &&
             data.brand is string &&
             data.model is string &&
             data.city is string &&
             data.foundBy is string &&
             data.finderCity is string &&
             data.recoveryNote is string &&
             data.recoveredAt == request.time;
    }

    // RECOVERIES COLLECTION
    match /recoveries/{docId} {
      allow read: if true;
      allow create: if isSignedIn() && isValidRecovery(incoming());
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // PHONE REGISTRY COLLECTION
    match /phones/{reportId} {
      allow read: if true;
      allow create: if isSignedIn() && isValidId(reportId) && isValidReport(incoming()) && incoming().userId == request.auth.uid && incoming().status == 'pending' && incoming().verified == false && incoming().createdAt == request.time;
      allow update: if isSignedIn() && (isAdmin() || (isOwner(existing().userId) && incoming().userId == existing().userId && incoming().imei == existing().imei && incoming().createdAt == existing().createdAt));
      allow delete: if isAdmin() || isOwner(existing().userId);
    }

    // TRASH SYSTEM
    match /trash/{docId} {
      allow read, write: if isAdmin();
    }

    // SUPPORTING COLLECTIONS
    match /reports/{docId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update, delete: if isAdmin() || isOwner(existing().userId);
    }

    match /flagged/{docId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isAdmin() || isOwner(existing().userId);
    }
  }
}
